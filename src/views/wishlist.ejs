<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Luxury Wishlist</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4f46e5;
            --bg: #f3f4f6;
            --card-bg: #ffffff;
            --text-title: #111827;
            --text-price: #dc2626;
            --border: #e5e7eb;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            color: var(--text-title);
        }

        /* Bố cục chính dùng Grid: Trái rộng, Phải làm sidebar */
        .dashboard {
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 30px;
            width: 100%;
            max-width: 1200px;
        }

        /* Tiêu đề phần */
        .section-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* BÊN TRÁI: HIỂN THỊ DẠNG LƯỚI (GRID) */
        .wishlist-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }

        .product-card {
            background: var(--card-bg);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            border: 1px solid var(--border);
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
        }

        .product-card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            background: #eee;
        }

        .product-info {
            padding: 15px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .product-name {
            font-weight: 600;
            margin: 0 0 8px 0;
            font-size: 1rem;
            /* Giới hạn 2 dòng cho tên sản phẩm */
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-price {
            color: var(--text-price);
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 15px;
        }

        .btn-buy {
            width: 100%;
            background: #ecfdf5;
            color: #059669;
            border: 1px solid #d1fae5;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .btn-buy:hover {
            background: #10b981;
            color: white;
        }

        /* BÊN PHẢI: SIDEBAR NHẬP LIỆU CỐ ĐỊNH */
        .sidebar {
            position: sticky;
            top: 20px;
            height: fit-content;
            background: var(--card-bg);
            padding: 25px;
            border-radius: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            border: 1px solid var(--border);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .input-item {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .input-item label {
            font-size: 0.8rem;
            font-weight: 700;
            color: #6b7280;
        }

        input {
            width: 100%;
            padding: 12px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            box-sizing: border-box;
            outline: none;
            font-size: 0.95rem;
            transition: border-color 0.2s;
        }

        input:focus {
            border-color: var(--primary);
        }

        .btn-add {
            background: var(--primary);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 10px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 10px;
            transition: opacity 0.2s;
        }

        .btn-add:hover {
            opacity: 0.9;
        }

        /* Responsive cho máy tính bảng và điện thoại */
        @media (max-width: 900px) {
            .dashboard {
                grid-template-columns: 1fr;
            }
            .sidebar {
                position: static;
                order: -1; /* Đẩy form lên trên cùng khi dùng điện thoại */
            }
        }
    </style>
</head>
<body>

    <div class="dashboard">
        <div class="content-area">
            <div class="section-title">🛒 Danh sách (<%= items.length %>)</div>
            
            <div class="wishlist-grid" id="list-container">
                <% if (items.length > 0) { %>
                    <% items.forEach(item => { %>
                        <div class="product-card">
                            <img src="<%= item.imageUrl || 'https://cdn-icons-png.flaticon.com/512/1162/1162456.png' %>" alt="Product">
                            <div class="product-info">
                                <div>
                                    <h3 class="product-name"><%= item.productName %></h3>
                                    <div class="product-price"><%= item.price %> đ</div>
                                </div>
                                <form action="/wishlist/bought/<%= item._id %>" method="POST">
                                    <button type="submit" class="btn-buy">mua ngay</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div style="grid-column: 1/-1; text-align: center; padding: 60px; color: #9ca3af; background: white; border-radius: 16px;">
                        Bạn chưa có ước muốn nào. Hãy thêm ở bên cạnh!
                    </div>
                <% } %>
            </div>
        </div>

        <div class="sidebar">
            <div class="section-title" style="font-size: 1.2rem;">✨ Thêm món đồ mới</div>
            <form action="/wishlist/add" method="POST" class="form-group">
                <div class="input-item">
                    <label>TÊN SẢN PHẨM</label>
                    <input type="text" name="productName" placeholder="Tên sản phẩm" required>
                </div>
                
                <div class="input-item">
                    <label>GIÁ DỰ KIẾN (VNĐ)</label>
                    <input type="text" name="price" id="priceInput" placeholder="0">
                </div>
                
                <div class="input-item">
                    <label>LINK ẢNH SẢN PHẨM</label>
                    <input type="text" name="imageUrl" placeholder="Dán link Sản phẩm (tùy chọn)">
                </div>
                
                <button type="submit" class="btn-add">THÊM VÀO DANH SÁCH</button>
            </form>
        </div>
    </div>

    <script>
        document.getElementById('priceInput').oninput = (e) => {
            let val = e.target.value.replace(/\D/g, "");
            e.target.value = val.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        };
    </script>
</body>
</html>
